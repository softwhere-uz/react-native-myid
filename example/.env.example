# MyID credentials for the example app's "Real device" mode.
# Copy this file to example/.env (git-ignored) and fill in real values.
#
# The modern MyID 3.1.x flow uses a SERVER-MINTED sessionId: mint one per launch
# from YOUR backend using your clientHash/clientHashId. The legacy clientId flow
# is not supported by the current SDK. These are your own MyID partnership
# credentials — never commit real values.
#
# `EXPO_PUBLIC_` vars are inlined into the JS bundle by Metro at build time.

EXPO_PUBLIC_MYID_SESSION_ID=
EXPO_PUBLIC_MYID_CLIENT_HASH=
EXPO_PUBLIC_MYID_CLIENT_HASH_ID=
